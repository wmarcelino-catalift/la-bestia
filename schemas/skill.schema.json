{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/wmarcelino-catalift/la-bestia/schemas/skill.schema.json",
  "title": "La Bestia — skill frontmatter",
  "description": "Validates the YAML frontmatter of every SKILL.md under config/skills/<name>/. Body is loaded only on trigger (progressive disclosure).",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "description", "triggers"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,30}[a-z0-9]$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[a-z0-9.-]+)?$",
      "description": "Strict SemVer 2.0.0"
    },
    "description": {
      "type": "string",
      "minLength": 30,
      "maxLength": 400
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 40
      },
      "description": "Keywords that auto-load this skill when present in user prompts"
    }
  }
}
