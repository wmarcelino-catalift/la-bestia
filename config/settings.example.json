{
  "env": {
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "8000",
    "OBSIDIAN_VAULT": "$HOME/Obsidian/claude-brain"
  },
  "permissions": {
    "allow": [
      "Read", "Glob", "Grep",
      "Bash(git status*)", "Bash(git log*)", "Bash(git diff*)",
      "Bash(git branch*)", "Bash(git show*)", "Bash(git rev-parse*)",
      "Bash(ls *)", "Bash(cat *)", "Bash(head *)", "Bash(tail *)",
      "Bash(wc *)", "Bash(find *)", "Bash(jq *)",
      "Bash(ccusage*)", "Bash(bash ~/.claude/scripts/*)"
    ],
    "deny": [
      "Bash(rm -rf /)", "Bash(rm -rf /*)", "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME*)", "Bash(sudo rm -rf*)",
      "Bash(DROP DATABASE*)", "Bash(DROP TABLE*)", "Bash(TRUNCATE*)",
      "Bash(mkfs*)", "Bash(dd if=*)", "Bash(chmod 777*)",
      "Bash(curl * | bash)", "Bash(curl * | sh)",
      "Bash(wget * | bash)", "Bash(wget * | sh)",
      "Bash(git push --force*)", "Bash(git push -f*)",
      "Bash(git reset --hard*)", "Bash(npm publish*)",
      "Write(**/.env)", "Write(**/.env.*)", "Write(**/*.pem)",
      "Write(**/*.key)", "Write(**/*.p12)", "Write(**/*.pfx)",
      "Write(**/credentials*.json)", "Write(**/service-account*.json)",
      "Write(**/firebase-adminsdk*.json)", "Write(**/id_rsa*)",
      "Edit(**/.env)", "Edit(**/.env.*)", "Edit(**/*.pem)",
      "Edit(**/*.key)", "Edit(**/credentials*.json)",
      "Edit(**/service-account*.json)", "Edit(**/firebase-adminsdk*.json)"
    ],
    "ask": [
      "Bash(git push*)", "Bash(npm install*)", "Bash(pip install*)",
      "Bash(brew install*)", "Bash(docker run*)", "Bash(docker build*)"
    ]
  },
  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "CMD=$(echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.command // \"\"'); echo \"$CMD\" | grep -qE '\\brm -rf /|\\bDROP (TABLE|DATABASE)|\\bTRUNCATE\\b|\\bgit push.*--force.*(main|master)|sudo rm -rf|>\\s*/dev/sd[a-z]' && { echo 'BLOCKED: dangerous command detected' >&2; exit 2; }; exit 0",
          "async": true
        }]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{"type": "command", "command": "bash ~/.claude/hooks/block-secrets.sh"}]
      },
      {
        "matcher": "Task|Bash|Write|Edit|Read",
        "hooks": [{"type": "command", "command": "bash ~/.claude/scripts/live-update.sh pre \"$(echo $CLAUDE_TOOL_NAME)\" 2>/dev/null", "async": true}]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{
          "type": "command",
          "command": "FILE=$(echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.file_path // .new_path // \"\"'); if [ -z \"$FILE\" ] || [ ! -f \"$FILE\" ]; then exit 0; fi; case \"$FILE\" in *.ts|*.tsx|*.js|*.jsx|*.json|*.css|*.html) command -v npx >/dev/null 2>&1 && npx --no-install prettier --write \"$FILE\" 2>/dev/null ;; *.py) command -v ruff >/dev/null 2>&1 && ruff format \"$FILE\" 2>/dev/null ;; *.go) command -v gofmt >/dev/null 2>&1 && gofmt -w \"$FILE\" 2>/dev/null ;; esac; exit 0"
        }]
      },
      {
        "matcher": "Task|Bash",
        "hooks": [{"type": "command", "command": "bash ~/.claude/hooks/log-agents.sh"}]
      },
      {
        "matcher": "Task|Bash|Write|Edit|Read",
        "hooks": [{"type": "command", "command": "bash ~/.claude/scripts/live-update.sh post \"$(echo $CLAUDE_TOOL_NAME)\" 2>/dev/null", "async": true}]
      }
    ],
    "SessionStart": [
      {"hooks": [{"type": "command", "command": "bash ~/.claude/hooks/inject-context.sh"}]}
    ],
    "UserPromptSubmit": [
      {"hooks": [{"type": "command", "command": "bash ~/.claude/hooks/route-prompt.sh"}]}
    ],
    "Stop": [
      {"hooks": [{"type": "command", "command": "bash ~/.claude/hooks/log-session.sh"}]}
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/scripts/statusline.sh"
  },
  "effortLevel": "medium"
}
